# .env — 项目配置文件
# 复制为 .env 后修改，其他文件无需改动。

# ── 必须配置 ─────────────────────────────────────────────────────────────────

# wechat-decrypt 服务地址
# 启动方式：cd /path/to/wechat-decrypt && sudo ./find_all_keys_macos && python3 main.py
WECHAT_DECRYPT_URL=http://localhost:5678

# 目标微信群关键词（逗号分隔，群名包含任意一个即纳入）
GROUP_KEYWORDS=你的群关键词1,你的群关键词2

# KnowWind 服务地址（wx-still 会把提取结果推送到这里）
KNOWWIND_URL=http://localhost:8000

# KnowWind 鉴权 Token（如果 KnowWind 开启了鉴权）
KNOWWIND_TOKEN=

# ── 可选配置（有默认值，一般不需要改）───────────────────────────────────────

# LLM 模型（用于 insight 提取和策略转换）
ANTHROPIC_MODEL=claude-opus-4-5

# 有效问题的最短字符数
MIN_QUESTION_LENGTH=8
